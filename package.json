{
  "name": "brvm-exogenous-predictor",
  "version": "1.0.0",
  "description": "BRVM Stock Prediction System using Exogenous Variables - Real-time scraping & forecasting",
  "main": "scraping/engine/index.js",
  "directories": {
    "data": "data",
    "scraping": "scraping",
    "models": "models"
  },
  "scripts": {
    "scrape:brvm": "node scraping/engine/collect-brvm.js",
    "scrape:commodities": "node scraping/engine/collect-commodities.js",
    "scrape:all": "node scraping/engine/index.js",
    "predict:realtime": "node models/predict-realtime.js",
